<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.view.MainPage">
   
   <!-- 1. 极左侧边栏 (Sidebar) -->
   <left>
      <HBox>
         <VBox prefWidth="60.0" style="-fx-background-color: #2e2e2e; -fx-alignment: TOP_CENTER; -fx-padding: 20 0 0 0; -fx-spacing: 20;">
            <children>
               <!-- 用户头像 -->
               <StackPane>
                  <Circle radius="20.0" fill="#1e90ff" />
                  <Label text="Me" textFill="WHITE" style="-fx-font-weight: bold;" />
               </StackPane>
               
               <!-- 导航图标 (用按钮模拟) -->
               <Button text="💬" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px;">
                  <tooltip><Tooltip text="Chats" /></tooltip>
               </Button>
               <Button text="👥" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 20px;">
                  <tooltip><Tooltip text="Contacts" /></tooltip>
               </Button>
               <Button text="📂" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 20px;">
                  <tooltip><Tooltip text="Files" /></tooltip>
               </Button>
               
               <VBox VBox.vgrow="ALWAYS" /> <!-- 占位符，推到底部 -->
               
               <Button text="⚙️" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 20px; -fx-padding: 0 0 20 0;">
                  <tooltip><Tooltip text="Settings" /></tooltip>
               </Button>
            </children>
         </VBox>

         <!-- 2. 列表栏 (List Panel) -->
         <VBox prefWidth="250.0" style="-fx-background-color: #f7f7f7; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">
            <children>
               <!-- 搜索栏 + 添加按钮 -->
               <HBox spacing="10.0" alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #f7f7f7;">
                  <TextField promptText="Search" style="-fx-background-radius: 15; -fx-background-color: #e0e0e0;" HBox.hgrow="ALWAYS" />
                  <Button text="+" style="-fx-background-radius: 15; -fx-min-width: 30; -fx-background-color: #e0e0e0;" onAction="#onAddButtonClick">
                     <tooltip><Tooltip text="Add Friend / Create Group" /></tooltip>
                  </Button>
               </HBox>
               
               <!-- 聊天/联系人列表 -->
               <ListView fx:id="chatListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0;" />
            </children>
         </VBox>
      </HBox>
   </left>

   <!-- 3. 内容区域 (Content Area) -->
   <center>
      <VBox style="-fx-background-color: white;">
         <children>
            <!-- 标题栏 -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
               <Label fx:id="currentChatLabel" text="Select a chat" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
               <VBox HBox.hgrow="ALWAYS" />
               <Button text="•••" style="-fx-background-color: transparent; -fx-font-size: 16px;" />
            </HBox>
            
            <!-- 消息列表 -->
            <ListView fx:id="messageListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0; -fx-padding: 10;" />
            
            <!-- 输入区域 -->
            <VBox style="-fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0; -fx-min-height: 150;">
               <children>
                  <!-- 工具栏 -->
                  <HBox spacing="15.0" style="-fx-padding: 10;">
                     <Button text="😊" style="-fx-background-color: transparent;" />
                     <Button text="📁" style="-fx-background-color: transparent;" />
                     <Button text="✂️" style="-fx-background-color: transparent;" />
                  </HBox>
                  
                  <!-- 输入框 -->
                  <TextField fx:id="inputField" alignment="TOP_LEFT" promptText="Type a message..." VBox.vgrow="ALWAYS" 
                             style="-fx-background-color: transparent; -fx-padding: 10;" onAction="#onSendMessage" />
                  
                  <!-- 发送按钮栏 -->
                  <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
                     <Button text="Send (Enter)" onAction="#onSendMessage" 
                             style="-fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-background-radius: 4; -fx-padding: 5 20;" />
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
